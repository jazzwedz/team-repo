# ============================================================
# Team Repository — environment variables
# Copy this file to .env.local and fill in the values.
# .env*.local is gitignored — never commit real secrets.
# ============================================================

# --- Required: Git storage backend ---
# Pick ONE of the three providers below by setting GIT_PROVIDER.
# Defaults to "github" when unset.
#
#   GIT_PROVIDER=github     → store catalog in a GitHub repo
#   GIT_PROVIDER=ado        → store catalog in Azure DevOps Git
#                             (also accepts: "azure-devops")
#   GIT_PROVIDER=filesystem → store catalog in a local or shared
#                             directory on the filesystem
#                             (also accepts: "fs", "file")
GIT_PROVIDER=github

# --- Provider: GitHub ---
# Fine-grained PAT with "Contents: Read and write" on the data repo.
# Create at: https://github.com/settings/personal-access-tokens
GITHUB_TOKEN=
# GitHub user or org that owns the data repo.
GITHUB_OWNER=
# Repo name (any empty repo you own; defaults to "arch-data").
GITHUB_REPO=arch-data
# Branch to commit into.
GITHUB_BRANCH=main

# --- Provider: Azure DevOps ---
# Base URL of the organisation (Service) or collection (on-prem Server/TFS):
#   ADO Service:  https://dev.azure.com/{your-org}
#   ADO Server:   https://your-tfs.example.com/DefaultCollection
# No trailing slash.
# ADO_BASE_URL=
# Project name inside the organisation / collection.
# ADO_PROJECT=
# Git repository name (any empty repo).
# ADO_REPO=arch-data
# Branch to commit into.
# ADO_BRANCH=main
# Personal Access Token with at least "Code (Read & Write)" on the repo.
# Create at: https://dev.azure.com/{your-org}/_usersSettings/tokens
# ADO_PAT=

# --- Provider: Filesystem ---
# Absolute path to the directory that holds the catalog. The process
# user needs read + write permission. The directory itself must already
# exist; sub-directories (components/, diagrams/, confluence-links/,
# _history/, _locks/) are created on demand from the Settings page's
# "Initialize storage" button.
#
# Windows examples:
#   FS_STORAGE_PATH=C:\arch-tool-data
#   FS_STORAGE_PATH=\\file-server.example.com\share\arch-tool-data
# Linux / macOS examples:
#   FS_STORAGE_PATH=/var/lib/arch-tool/data
#   FS_STORAGE_PATH=/mnt/shared/arch-tool-data
# FS_STORAGE_PATH=
#
# Multi-user identification: when the deployment sits behind a reverse
# proxy that authenticates users (Kerberos / SAML / OIDC), the proxy is
# expected to inject the authenticated username into a request header.
# arch-tool reads that header for edit-lock ownership and history
# sidecar entries. Defaults to X-Forwarded-User if unset.
# USER_HEADER=X-Forwarded-User

# --- Required: LLM provider ---
# Powers Generate, Blast Radius AI Memo, and Pull-smart.
#
# Pick ONE of the two providers below by setting LLM_PROVIDER.
# Defaults to "anthropic" when unset.
#
#   LLM_PROVIDER=anthropic           → use Anthropic Claude directly
#   LLM_PROVIDER=openai-compatible   → use any OpenAI Chat Completions
#                                      gateway: OpenAI, Azure OpenAI,
#                                      OpenRouter, Together, Groq,
#                                      LiteLLM, Portkey, Cloudflare
#                                      AI Gateway, Ollama, LM Studio, vllm
LLM_PROVIDER=anthropic

# --- Provider: Anthropic ---
# API key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Optional model override. Falls back to config.yaml (llm.model)
# then to a built-in default. Example: claude-sonnet-4-20250514.
# ANTHROPIC_MODEL=

# --- Provider: openai-compatible ---
# Base URL of the gateway, no trailing slash. The adapter calls
# {LLM_BASE_URL}/chat/completions. Examples:
#   https://api.openai.com/v1
#   https://your-resource.openai.azure.com/openai/deployments/your-deployment
#   https://openrouter.ai/api/v1
#   https://your-gateway.example.com/v1
# LLM_BASE_URL=
# Optional model override. Falls back to config.yaml (llm.model)
# then to a built-in default. Example: gpt-4o, claude-3-5-sonnet, etc.
# LLM_MODEL=
#
# Pick ONE of the two authentication modes below:
#
# (a) Static bearer token — default. Use when the gateway accepts a
# long-lived API key directly in the Authorization header.
# LLM_API_KEY=
#
# (b) OAuth 2.0 client_credentials — for enterprise gateways behind an
# identity provider. Setting LLM_OAUTH_TOKEN_URL switches the adapter
# into OAuth mode; LLM_API_KEY is then ignored. Works with any
# standards-compliant IdP — the token URL is explicit so no vendor is
# assumed. Common examples:
#
#   Microsoft Entra ID:
#     LLM_OAUTH_TOKEN_URL=https://login.microsoftonline.com/{tenant-id}/oauth2/v2.0/token
#     LLM_OAUTH_SCOPE=api://{your-gateway-app-uri}/.default
#
#   Okta:
#     LLM_OAUTH_TOKEN_URL=https://{your-org}.okta.com/oauth2/default/v1/token
#     LLM_OAUTH_SCOPE={your-scope}
#
#   Auth0:
#     LLM_OAUTH_TOKEN_URL=https://{your-tenant}.auth0.com/oauth/token
#     LLM_OAUTH_AUDIENCE={your-api-identifier}
#
#   Keycloak / generic OpenID Connect IdP:
#     LLM_OAUTH_TOKEN_URL=https://your-idp.example.com/realms/{realm}/protocol/openid-connect/token
#     LLM_OAUTH_SCOPE={your-scope}
#
# LLM_OAUTH_TOKEN_URL=
# LLM_OAUTH_CLIENT_ID=
# LLM_OAUTH_CLIENT_SECRET=
# Set scope OR audience depending on what your IdP expects (most use
# scope; Auth0 uses audience; a few want both).
# LLM_OAUTH_SCOPE=
# LLM_OAUTH_AUDIENCE=

# --- Required: single-user password gate ---
# Shared password for the password gate (middleware.ts).
# Set a strong value; users sign in with this on /login.
SITE_PASSWORD=

# --- Optional: Confluence integration ---
# Enables Publish, Open in Confluence, and Pull from Confluence.
# Leave the required block for your edition empty to hide those buttons.
#
# Pick ONE edition by setting CONFLUENCE_EDITION (defaults to "cloud"):
#
#   CONFLUENCE_EDITION=cloud        → Atlassian Cloud, v2 API, Basic auth
#   CONFLUENCE_EDITION=datacenter   → Data Center / Server, v1 API, PAT
CONFLUENCE_EDITION=cloud

# Site root, no trailing slash. Works for both editions:
#   Cloud:      https://your-org.atlassian.net
#   DC/Server:  https://confluence.your-company.com
CONFLUENCE_BASE_URL=

# --- Edition: Cloud ---
# Atlassian account email used with the token below.
CONFLUENCE_EMAIL=
# API token from: https://id.atlassian.com/manage-profile/security/api-tokens
CONFLUENCE_API_TOKEN=
# Numeric space ID. Discover via:
#   curl -u "$EMAIL:$TOKEN" "$BASE/wiki/api/v2/spaces?keys=YOURKEY"
CONFLUENCE_SPACE_ID=
# Space key (e.g. TR). Used for nicer URL paths on Cloud, primary
# identifier on Data Center.
CONFLUENCE_SPACE_KEY=

# --- Edition: Data Center / Server ---
# Personal Access Token with read+write on the target space.
# Create at: <BASE>/plugins/personalaccesstokens/usertokens.action
# CONFLUENCE_PAT=
# (CONFLUENCE_SPACE_KEY above is also required on Data Center)

# --- Optional: app self-reference ---
# Public URL of this deployment. Embedded as the "source" link
# on every Confluence page published from this instance.
ARCH_TOOL_PUBLIC_URL=

# --- Optional: Source code repository (read-only, Azure DevOps) ---
# A SEPARATE connection from the catalog data repo above. Points at the
# actual application source code in Azure DevOps so a future consistency
# check can read code as evidence for what the catalog claims. Read-only:
# use a PAT scoped to "Code (Read)". Verify it under Settings → Health
# checks → "Source code (ADO)". MVP supports one repo.
# Base URL — ADO Service: https://dev.azure.com/{org}
#            ADO Server:  https://your-server/{collection}   (no trailing slash)
# SRC_ADO_BASE_URL=
# SRC_ADO_PROJECT=
# SRC_ADO_REPO=
# SRC_ADO_BRANCH=main
# Read-only PAT (scope: Code → Read).
# SRC_ADO_PAT=

# --- Optional: Data Model Registry integration (v0.6+) ---
# Read-only one-way pull from an external REST metadata service that
# exposes entity definitions + entity-to-entity relationships. Only
# components of type `table` get the linker UI. The catalog stores the
# entity name; attributes and relationships are fetched live so the
# registry stays the source of truth.
#
# Leave DATA_MODEL_REGISTRY_BASE_URL empty to disable the integration
# (the linker card on the form and the registry card on the detail
# page both silently hide themselves).
#
# DATA_MODEL_REGISTRY_BASE_URL=https://datamodel-service.your-corp.example.com
# DATA_MODEL_REGISTRY_API_PATH=/api/v1/
# DATA_MODEL_REGISTRY_ENTITY_PATH=/dataModel/version
# DATA_MODEL_REGISTRY_RELATIONSHIPS_PATH=/relationships
# DATA_MODEL_REGISTRY_ZONE=PRD
#
# Authentication mode: bearer (default) | oauth
# DATA_MODEL_REGISTRY_AUTH=bearer
#
# Bearer mode — static long-lived token
# DATA_MODEL_REGISTRY_TOKEN=
#
# OAuth mode — OAuth 2.0 client_credentials. Same shape as the LLM
# gateway adapter; works with Microsoft Entra ID, Okta, Auth0,
# Keycloak, AWS Cognito and any other standards-compliant IdP.
# DATA_MODEL_REGISTRY_OAUTH_TOKEN_URL=
# DATA_MODEL_REGISTRY_OAUTH_CLIENT_ID=
# DATA_MODEL_REGISTRY_OAUTH_CLIENT_SECRET=
# DATA_MODEL_REGISTRY_OAUTH_SCOPE=
# DATA_MODEL_REGISTRY_OAUTH_AUDIENCE=

# --- Optional: Logging (v0.5+) ---
# Default behaviour is "stdout, info level, full LLM logs" — drop-in
# safe for any deployment. Set the file sink + LOG_PATH when you want
# the Admin console (/admin) to browse history.
#
# Log level threshold: debug | info | warn | error
# LOG_LEVEL=info
#
# Sink: stdout | file | both
#   stdout  → whatever runs the process collects the JSON lines
#   file    → per-day per-stream files under LOG_PATH:
#               app.YYYY-MM-DD.jsonl              operational entries
#               llm.YYYY-MM-DD.jsonl              LLM call traces
#               admin-actions.YYYY-MM-DD.jsonl    admin audit
#   both    → stdout + file (recommended for corp)
# LOG_SINK=stdout
#
# Required when LOG_SINK is "file" or "both". Process user needs
# read+write here. Independent of GIT_PROVIDER / FS_STORAGE_PATH.
# Windows example:  LOG_PATH=C:\arch-tool-logs
# Linux example:    LOG_PATH=/var/log/arch-tool
# LOG_PATH=./logs
#
# LLM log fidelity: "true" (default) keeps the full prompt + response on
# disk for fine-tuning analysis in the Admin console; "summary" keeps
# only metadata (length, latency, ok/err) and never writes prompt text.
# LLM_LOG_FULL=true
