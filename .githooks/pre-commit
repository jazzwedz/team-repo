#!/bin/sh
# Vendor-neutrality guard. Rejects a commit whose ADDED lines contain a
# blocked vendor-specific term. The patterns use bracket escapes so this
# hook file itself contains no flaggable literal (a plain "sw"+"iss" would
# trip scanners and the hook itself).
#
# Enable once per clone:  git config core.hooksPath .githooks
# Override (rare, intentional):  git commit --no-verify

pattern='sw[i]ss|atlan[t]is|g[f]dm|gf[p]\.'

if git diff --cached -U0 --no-color | grep -nEi "^\+.*(${pattern})" >/dev/null; then
  echo "pre-commit: staged changes contain a blocked vendor term." >&2
  echo "  pattern: ${pattern}" >&2
  echo "  Remove it before committing (or, if truly intended, use --no-verify)." >&2
  exit 1
fi

exit 0
